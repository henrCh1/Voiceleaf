<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light window chrome. Compose draws the real UI; this styles the window + status bar. -->
    <style name="Theme.V2J" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/paper</item>
        <item name="android:statusBarColor">@color/paper</item>
        <item name="android:navigationBarColor">@color/paper</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
